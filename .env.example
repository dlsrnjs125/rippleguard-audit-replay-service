# Copy to .env and fill local secret values.
# Never commit .env.

DB_URL=jdbc:postgresql://localhost:5435/rippleguard_audit
DB_USERNAME=rippleguard_audit
DB_PASSWORD=

KAFKA_BOOTSTRAP_SERVERS=localhost:9094
KAFKA_CONSUMER_GROUP=rippleguard-audit-replay-service

AUDIT_KAFKA_ENABLED=true
TOPIC_LOAN_APPLICATION_SUBMITTED=loan.application.submitted.v1
TOPIC_GOVERNANCE_REVIEW_STARTED=governance.review.started.v1
TOPIC_AGENT_EVALUATION_REQUESTED=agent.evaluation.requested.v1
TOPIC_AGENT_EVALUATION_COMPLETED=agent.evaluation.completed.v1
TOPIC_GOVERNANCE_AGENT_RESULT_VALIDATED=governance.agent-result.validated.v1
TOPIC_LOAN_DECISION_COMMANDED=loan.decision.commanded.v1
TOPIC_LOAN_DECISION_FINALIZED=loan.decision.finalized.v1
