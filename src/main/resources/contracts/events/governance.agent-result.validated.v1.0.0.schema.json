{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Governance Agent Result Validated v1.0.0",
  "description": "Governance-owned audit event emitted after validating a Phase 2 Agent result. Agent Runtime must not produce this event.",
  "allOf": [
    { "$ref": "../common/phase-1-event-envelope-profile.v1.0.0.schema.json" },
    {
      "properties": {
        "producer": { "const": "governance-service" },
        "eventType": { "const": "governance.agent-result.validated.v1" },
        "schemaVersion": { "const": "1.0.0" },
        "causationId": { "type": "string", "format": "uuid" },
        "payload": {
          "type": "object",
          "properties": {
            "decisionCaseId": { "type": "string", "minLength": 1 },
            "evaluationRunId": { "type": "string", "format": "uuid" },
            "agentRunId": { "type": "string", "format": "uuid" },
            "attemptId": { "type": "integer", "minimum": 1 },
            "agentResultReference": { "type": "string", "pattern": "^agent-result://.+" },
            "agentResultDigest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
            "validationOutcome": { "type": "string", "enum": ["VALIDATED", "REJECTED"] },
            "validationReasonCodes": {
              "type": "array",
              "items": { "type": "string", "enum": ["SCHEMA_VALID", "SCHEMA_INVALID", "MODEL_PROVENANCE_VALID", "MODEL_PROVENANCE_INVALID", "SNAPSHOT_MATCHED", "SNAPSHOT_MISMATCH", "SHAP_PRESENT", "SHAP_MISSING", "AGENT_FAILURE_RECORDED"] },
              "minItems": 1,
              "uniqueItems": true
            },
            "validatedSchemaVersion": { "const": "1.0.0" },
            "validatedAt": { "type": "string", "format": "date-time", "pattern": "T.*(?:Z|[+-][0-9]{2}:[0-9]{2})$" }
          },
          "required": ["decisionCaseId", "evaluationRunId", "agentRunId", "attemptId", "agentResultReference", "agentResultDigest", "validationOutcome", "validationReasonCodes", "validatedSchemaVersion", "validatedAt"],
          "additionalProperties": false,
          "oneOf": [
            {
              "properties": {
                "validationOutcome": { "const": "VALIDATED" },
                "validationReasonCodes": {
                  "allOf": [
                    { "contains": { "const": "SCHEMA_VALID" } },
                    { "contains": { "const": "MODEL_PROVENANCE_VALID" } },
                    { "contains": { "const": "SNAPSHOT_MATCHED" } },
                    { "contains": { "const": "SHAP_PRESENT" } },
                    { "not": { "contains": { "enum": ["SCHEMA_INVALID", "MODEL_PROVENANCE_INVALID", "SNAPSHOT_MISMATCH", "SHAP_MISSING", "AGENT_FAILURE_RECORDED"] } } }
                  ]
                }
              }
            },
            {
              "properties": {
                "validationOutcome": { "const": "REJECTED" },
                "validationReasonCodes": {
                  "contains": { "enum": ["SCHEMA_INVALID", "MODEL_PROVENANCE_INVALID", "SNAPSHOT_MISMATCH", "SHAP_MISSING", "AGENT_FAILURE_RECORDED"] },
                  "not": {
                    "allOf": [
                      { "contains": { "const": "SCHEMA_VALID" } },
                      { "contains": { "const": "MODEL_PROVENANCE_VALID" } },
                      { "contains": { "const": "SNAPSHOT_MATCHED" } },
                      { "contains": { "const": "SHAP_PRESENT" } }
                    ]
                  }
                }
              }
            }
          ]
        }
      }
    }
  ],
  "unevaluatedProperties": false
}
